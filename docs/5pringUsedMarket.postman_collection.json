      "name": "0. Health Check",
      "item": [
        {
          "name": "0-1. Actuator Health",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            },
            "description": "배포 Health Check용 Actuator 엔드포인트입니다. health만 노출하며 Redis 컴포넌트 연결 상태를 함께 확인합니다."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('Actuator health is UP', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json).to.have.property('status', 'UP');",
                  "});",
                  "pm.test('Redis health is UP', function () {",
                  "  pm.expect(json.components).to.have.property('redis');",
                  "  pm.expect(json.components.redis).to.have.property('status', 'UP');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
